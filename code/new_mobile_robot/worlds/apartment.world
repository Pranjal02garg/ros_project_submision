        <visual name="stem_visual">
          <pose>0 0 0.55 0 0 0</pose>
          <geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry>
          <material><ambient>0.1 0.35 0.1 1</ambient><diffuse>0.1 0.35 0.1 1</diffuse></material>
        </visual>

        <visual name="leaves_visual">
          <pose>0 0 0.95 0 0 0</pose>
          <geometry><sphere><radius>0.35</radius></sphere></geometry>
          <material><ambient>0.05 0.45 0.08 1</ambient><diffuse>0.05 0.45 0.08 1</diffuse></material>
        </visual>

      </link>
    </model>

    <!-- ================= TOP RIGHT: KITCHEN ================= -->
    <model name="kitchen_counter_realistic">
      <static>true</static>
      <pose>5.45 4.85 0 0 0 0</pose>
      <link name="link">

        <collision name="cabinet_collision">
          <pose>0 0 0.42 0 0 0</pose>
          <geometry><box><size>2.1 0.55 0.84</size></box></geometry>
        </collision>
        <visual name="cabinet_visual">
          <pose>0 0 0.42 0 0 0</pose>
          <geometry><box><size>2.1 0.55 0.84</size></box></geometry>
          <material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.42 0.42 0.40 1</diffuse></material>
        </visual>

        <collision name="countertop_collision">
          <pose>0 0 0.88 0 0 0</pose>
          <geometry><box><size>2.2 0.65 0.08</size></box></geometry>
        </collision>
        <visual name="countertop_visual">
          <pose>0 0 0.88 0 0 0</pose>
          <geometry><box><size>2.2 0.65 0.08</size></box></geometry>
          <material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.12 0.12 0.12 1</diffuse></material>
