    <model name="chair_1">
      <static>true</static>
      <pose>5.2 -4.5 0 0 0 0</pose>
      <link name="link">
        <collision name="seat_collision">
          <pose>0 0 0.35 0 0 0</pose>
          <geometry><box><size>0.42 0.42 0.08</size></box></geometry>
