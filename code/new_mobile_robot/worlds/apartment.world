    <model name="fridge_realistic">
      <static>true</static>
      <pose>7.1 1.25 0 0 0 0</pose>
      <link name="link">

        <collision name="body_collision">
          <pose>0 0 0.9 0 0 0</pose>
          <geometry><box><size>0.65 0.65 1.8</size></box></geometry>
        </collision>
        <visual name="body_visual">
          <pose>0 0 0.9 0 0 0</pose>
          <geometry><box><size>0.65 0.65 1.8</size></box></geometry>
          <material><ambient>0.88 0.88 0.86 1</ambient><diffuse>0.88 0.88 0.86 1</diffuse></material>
